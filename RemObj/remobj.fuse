--[[--
Fuse Plugin for DaVinci Resolve
--------------------------------------------------------------
Fuse Name: Remobj
Date Created: 2026-07-04
Fuse Version: 0.1
Author: Akascape
Fuse Category: Effect
Description: Object Removal/Inpainting using LaMa ONNX model
--------------------------------------------------------------
--]]--

version = 0.1
fuse_data = [=[
This is a Fuse for DaVinci Resolve that uses the LaMa ONNX model to remove/inpaint objects from images.

Repo Link: https://github.com/Akascape/RemObj-Fuse
License: MIT Copyright (c) 2026 Akascape

How to use:
1. Connect the main footage to the Orange/Yellow input for this fuse node.
2. Connect the mask to the Green/Secondary input.
3. Configure Python path if needed.
4. The object will be inpainted using the LaMa AI model.

----------------------------------
Get more plugins at www.akascape.com
----------------------------------
]=]

FuRegisterClass("RemObj", CT_Tool, {
    REGS_Category = "Effect",
    REGS_OpIconString = "RemObj",
    REGS_OpDescription = "Object Removal using LaMa",

    REG_NoObjMatCtrls = true,
    REG_NoMotionBlurCtrls = true,

    REG_Source_GlobalCtrls = false,
    REG_Source_SizeCtrls = true,
    REG_Source_AspectCtrls = true,
    REG_Source_DepthCtrls = true,
    REG_OpNoMask = false,
    REG_Fuse_NoEdit = true,
    REG_Fuse_NoReload = false,

    REG_TimeVariant = true,

    REGS_Company = "Akascape",
    REGS_URL = "www.akascape.com",
    REG_Version = version,
})

Logo_Image = [[
<center>
<img width="300" height="80" src='data:image/png;base64, '>
<div style="position: absolute; top: 0px; right: 0px; color: white; font-size: 11px; text-shadow: 1px 1px 2px black;">
    v0.1
</div>
</center>
]]

function Create()

    InImage = self:AddInput("Main Footage", "Image", {
        LINKID_DataType = "Image",
        LINK_Main = 1,
        INP_Required = true,
    })

    InMask = self:AddInput("Mask", "Mask", {
        LINKID_DataType = "Image",
        LINK_Main = 2,
        INP_Required = true,
    })

    InLabel = self:AddInput(Logo_Image, "Label", {
        LINKID_DataType = "Text",
        INPID_InputControl = "LabelControl",
        LBLC_MultiLine = true,
        INP_External = false,
        INP_Passive = true,
        IC_NoLabel = true,
        IC_NoReset = true,
        IC_ControlPage = -1,
    })

    InProgress = self:AddInput("Status", "Status", {
        LINKID_DataType = "Text",
        INPID_InputControl= "TextEditControl",
        TEC_Lines = 1, 
        TEC_Wrap = true,
        TEC_ReadOnly = true, 
        TEC_CharLimit = 40, 
        TEC_DeferSetInputs = true, 
        INP_External = false,
        INP_Passive = true,
    })

    local defaultPython = 'python3'
    local isWindows = os.getenv("OS") and string.find(os.getenv("OS"), "Windows")
    if isWindows then
        defaultPython = 'python'
        local pathEnv = os.getenv("PATH") or ""
        for dir in pathEnv:gmatch("[^;]+") do
            local f = io.open(dir .. "\\pythonw.exe", "r")
            if f then
                f:close()
                defaultPython = 'pythonw'
                break
            end
        end
    end
    self:SetData("default_pyexe", defaultPython)
    InPython = self:AddInput('Python Path', 'Python', {
        LINKID_DataType = 'Text',
        INPID_InputControl = 'FileControl',
        INP_DoNotifyChanged = true,
        INPS_DefaultText = defaultPython,
        FC_ClipBrowse = false,
        FC_IsSaver = false,
        INP_External = false
    })

    InSetup = self:AddInput("Open RemObj Setup", "OpenSetup", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ButtonControl",
        INP_External = false,
        INP_Passive = true,
        BTNCS_Execute  = [=[
        local setupPath = comp:MapPath('Fuses:/RemObj/remobj_manager.py')
        print("Running script: "..setupPath)

        local command
        local isWindows = os.getenv("OS") and string.find(os.getenv("OS"), "Windows")
        local isMac = jit and jit.os == "OSX"
        local isLinux = not isWindows and not isMac

        local pythonpath = tool:GetData("python_path")
        local default_py = tool:GetData("default_pyexe") or "python"
        local pyexe = pythonpath and pythonpath:match("%S+") or default_py
        if pyexe == "pythonw" and default_py == "python" then
            pyexe = "python"
        end

        if isWindows then
            command = 'start /B /MIN '.. pyexe .. ' "' .. setupPath .. '"'
        elseif isMac then
            command = '/bin/zsh -l -c "' .. pyexe .. ' \\"' .. setupPath .. '\\""'
        elseif isLinux then
            command = pyexe .. ' "' .. setupPath .. '"'
        end
        
        if setupPath then
            os.execute(command)
        else
            print("Setup file not found at: " .. setupPath)
        end
        ]=],
        INP_DoNotifyChanged = true,
    })

    self:AddControlPage("Help")

    InAbout =  self:AddInput("Made by Akascape | Version: "..tostring(version), "about_main", {
        LINKID_DataType    = "Text",
        INPID_InputControl = "LabelControl",
        INP_External       = false,
        INP_Passive        = true,
        ICD_Width          = 1,
    })

    InHelp = self:AddInput("", "help_box", {
        LINKID_DataType = "Text",
        INPID_InputControl= "TextEditControl",
        TEC_Lines = 15, 
        TEC_Wrap = true,
        ICD_Width = 1,
        TEC_ReadOnly = true, 
        TEC_DeferSetInputs = true, 
        INP_External = false,
        INP_Passive = true,
        INPS_DefaultText = fuse_data,
    })
    
    InDisableLogging = self:AddInput("Disable Logging", "DisableLogging", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Default = 0,
        INP_Integer = true,
        INP_External = false,
        INP_Passive = true,
    })

    OutImage = self:AddOutput("Output", "Output", {
        LINKID_DataType = "Image",
        LINK_Main = 1,
    })

end

function NotifyChanged(inp, param, time)
    if inp == InPython then
        local python_location = self.Comp:MapPath('Fuses:/RemObj/python_path.txt')
        local settings_folder = self.Comp:MapPath('Fuses:/RemObj/')
        if not bmd.direxists(settings_folder) then
            bmd.createdir(settings_folder)
        end
        if not bmd.fileexists(python_location) then
            local file = io.open(python_location, "w")
            if file then
                file:write(param.Value)
                file:close()
            end
        end
        if param.Value ~= "None" then
            local file = io.open(python_location, "w")
            if file then
                file:write(param.Value)
                file:close()
            end
        end
        local file = io.open(python_location, "r")
        if file then
            local python_path = file:read("*a")
            file:close()
            local default_py = self:GetData("default_pyexe") or "python"
            if python_path == "pythonw" and default_py == "python" then
                python_path = "python"
                local f = io.open(python_location, "w")
                if f then
                    f:write(python_path)
                    f:close()
                end
            end
            InPython:SetSource(Text(python_path), 0, 0)
            self:SetData("python_path", python_path)
        else
            self:SetData("python_path", param.Value)
        end
    end
end

logging_off = 0

function Process(req)
    
    local pythonScriptPath = self.Comp:MapPath('Fuses:/RemObj/obj_remover.py')
    logging_off = InDisableLogging:GetValue(req).Value or 0
    local src1
    local mask

    -- Create image attributes
    local imgattrs = {
        IMG_Document = self.Comp,
        { IMG_Channel = "Red", },
        { IMG_Channel = "Green", },
        { IMG_Channel = "Blue", },
        { IMG_Channel = "Alpha", },
        IMG_Width = Width,
        IMG_Height = Height,
        IMG_XScale = XAspect,
        IMG_YScale = YAspect,
        IMAT_OriginalWidth = realwidth,
        IMAT_OriginalHeight = realheight,
        IMG_Quality = not req:IsQuick(),
        IMG_MotionBlurQuality = not req:IsNoMotionBlur(),
    }
   
    if not req:IsStampOnly() then
        imgattrs.IMG_ProxyScale = 1
    end
    
    if SourceDepth ~= 0 then
        imgattrs.IMG_Depth = SourceDepth
    end

    if (InImage:GetValue(req) ~= nil) then
        src1 = InImage:GetValue(req)

        if (InMask:GetValue(req) ~= nil) then
            mask = InMask:GetValue(req)
            InProgress:SetSource(Text("[PROCESSING] Frame " .. req.Time), 0, 0)
            src1 = ProcessWithPython(src1, mask, pythonScriptPath, req.Time)
            InProgress:SetSource(Text("[COMPLETE] Frame "..req.Time),0,0)
        else
            InProgress:SetSource(Text("[WAITING] Connect Mask"),0,0)
        end
    else
        src1 = Image(imgattrs)
        local p = Pixel({R=0,G=0,B=0,A=0})
        src1:Fill(p)
    end
    
    OutImage:Set(req, src1)
end

function log(...)
    if logging_off == 1 then
        return
    end

    local args = {...}
    local out = {}
    for i = 1, #args do
        out[#out + 1] = tostring(args[i])
    end

    print(table.concat(out, " "))
end

function ProcessWithPython(inputImage, maskImage, scriptPath, frameTime)
    local tempDir = self.Comp:MapPath("Temp:/")
    local timeStamp = tostring(frameTime):gsub("%.", "_")
    local sep = package.config:sub(1,1)
    local inputImagePath = tempDir .. sep .. "remobj_input_" .. timeStamp
    local maskImagePath = tempDir .. sep .. "remobj_mask_" .. timeStamp
    local outputImagePath = tempDir .. sep .. "remobj_output_" .. timeStamp
    
    -- Save the input image using Fusion Clip method
    local input_clip = Clip(inputImagePath .. ".jpg", true)
    input_clip:Open()
    local putResult1 = input_clip:PutFrame(frameTime, inputImage)
    input_clip:Close()
    
    if not putResult1 then
        print("Failed to save input image to: " .. inputImagePath .. ".jpg")
        return inputImage
    end

    -- Save the mask image using Fusion Clip method (save as png for lossless mask)
    local mask_clip = Clip(maskImagePath .. ".png", true)
    mask_clip:Open()
    local putResult2 = mask_clip:PutFrame(frameTime, maskImage)
    mask_clip:Close()
    
    if not putResult2 then
        print("Failed to save mask image to: " .. maskImagePath .. ".png")
        pcall(function() os.remove(inputImagePath .. ".jpg") end)
        return inputImage
    end
    
    -- Build Python command
    local command
    local isWindows = os.getenv("OS") and string.find(os.getenv("OS"), "Windows")
    local isMac = jit and jit.os == "OSX"
    local isLinux = not isWindows and not isMac

    local pythonpath = self:GetData("python_path")
    local default_py = self:GetData("default_pyexe") or "python"
    local pyexe = pythonpath and pythonpath:match("%S+") or default_py
    if pyexe == "pythonw" and default_py == "python" then
        pyexe = "python"
    end
   
    if isWindows then
        command = string.format('start /B /MIN %s "%s" "%s.jpg" "%s.png" "%s.png"', 
            pyexe, scriptPath, inputImagePath, maskImagePath, outputImagePath)
    elseif isMac then
        command = string.format('/bin/zsh -l -c "%s \\"%s\\" \\"%s.jpg\\" \\"%s.png\\" \\"%s.png\\""',
            pyexe, scriptPath, inputImagePath, maskImagePath, outputImagePath)
    else
        command = string.format('%s "%s" "%s.jpg" "%s.png" "%s.png"', 
            pyexe, scriptPath, inputImagePath, maskImagePath, outputImagePath)
    end

    -- Execute Python script
    local handle = io.popen(command .. " 2>&1") 
    local result = ""
    local executionSuccess = false
    
    if handle then
        result = handle:read("*a")
        handle:close()
        executionSuccess = result and result:find("%[COMPLETE%]") ~= nil
        
        if executionSuccess then
            log("Python script executed successfully")
            if result and result ~= "" then
                log("Python output:", result)
            end
        else
            log("Python script failed with error:", result)
        end
    else
        log("Failed to execute Python script")
    end
    
    -- Load processed image if execution was successful
    local processedImage = inputImage  
    
    if executionSuccess then
        local outputFile = io.open(outputImagePath .. ".png", "r")
        if outputFile then
            outputFile:close()
            
            -- Load the processed image 
            local mappedPath = self.Comp:MapPath(outputImagePath .. ".png")
            local output_clip = Clip(mappedPath, false)
            output_clip:Open()
            local loadedImage = output_clip:GetFrame(0)
            output_clip:Close()
            
            if loadedImage then
                processedImage = loadedImage
                log("Successfully loaded processed image")
            else
                log("Failed to load processed image from: " .. mappedPath)
            end
        else
            log("Output image file not found: " .. outputImagePath .. ".png")
        end
    end
    
    -- Clean up temporary files
    pcall(function() os.remove(inputImagePath .. ".jpg") end)
    pcall(function() os.remove(maskImagePath .. ".png") end)
    pcall(function() os.remove(outputImagePath .. ".png") end)

    return processedImage
end
